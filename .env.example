# One Piece Data Pipeline Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# CHAPTER AND VOLUME SETTINGS
# =============================================================================
# Last chapter number to scrape (default: 1153)
OP_LAST_CHAPTER=1154

# Last volume number to scrape (default: 112)
OP_LAST_VOLUME=112

# =============================================================================
# DATA DIRECTORIES
# =============================================================================
# Directory where data files will be stored (default: ./data)
OP_DATA_DIR=./data

# Path to the DuckDB database file (default: ./data/onepiece.duckdb)
OP_DATABASE_PATH=./data/onepiece.duckdb

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
OP_LOG_LEVEL=INFO

# Path to the log file (default: ./logs/onepieceofdata.log)
OP_LOG_FILE=./logs/onepieceofdata.log

# =============================================================================
# SCRAPING CONFIGURATION
# =============================================================================
# Delay between requests in seconds to be respectful to the server (default: 1.0)
OP_SCRAPING_DELAY=1.0

# Maximum number of retries for failed requests (default: 3)
OP_MAX_RETRIES=3

# Request timeout in seconds (default: 30)
OP_REQUEST_TIMEOUT=30

# =============================================================================
# PARALLEL PROCESSING CONFIGURATION
# =============================================================================
# Enable parallel processing for scraping (default: false)
# Set to true to enable faster scraping with multiple workers
OP_ENABLE_PARALLEL=false

# Maximum number of worker threads for parallel processing (default: 4)
# Recommended: 2-8 depending on your system and to be respectful to the server
OP_MAX_WORKERS=7

# Number of items to process in each chunk for parallel processing (default: 10)
OP_PARALLEL_CHUNK_SIZE=10

# =============================================================================
# WEBSITE URLS
# =============================================================================
# Base URL for One Piece chapter pages on Fandom Wiki
OP_BASE_CHAPTER_URL=https://onepiece.fandom.com/wiki/Chapter_

# Base URL for One Piece character pages on Fandom Wiki
OP_BASE_CHARACTER_URL=https://onepiece.fandom.com/wiki/

# Base URL for One Piece volume pages on Fandom Wiki
OP_BASE_VOLUME_URL=https://onepiece.fandom.com/wiki/Volume_

# =============================================================================
# POSTGRESQL EXPORT CONFIGURATION
# =============================================================================
# PostgreSQL connection settings for exporting data
# Works with both local PostgreSQL and cloud PostgreSQL (Supabase)

# Option 1: Use full connection URL (recommended for Supabase)
# POSTGRES_URL=postgresql://user:password@host:port/database

# Option 2: Use individual settings (recommended for local development)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=onepiece
POSTGRES_USER=postgres
POSTGRES_PASSWORD=onepiece
POSTGRES_SSL_MODE=prefer

# Export batch size (number of rows per batch, default: 1000)
OP_EXPORT_BATCH_SIZE=1000

# Enable sync tracking (default: true)
OP_EXPORT_ENABLE_SYNC_TRACKING=true

# =============================================================================
# SUPABASE EXAMPLE CONFIGURATION
# =============================================================================
# For Supabase cloud PostgreSQL, uncomment and update these:
# POSTGRES_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# POSTGRES_SSL_MODE=require

# Or use individual settings:
# POSTGRES_HOST=aws-0-[REGION].pooler.supabase.com
# POSTGRES_PORT=5432
# POSTGRES_DB=postgres
# POSTGRES_USER=postgres.[PROJECT-REF]
# POSTGRES_PASSWORD=your-password-here
# POSTGRES_SSL_MODE=require

# =============================================================================
# SUPABASE STORAGE (for character thumbnails)
# =============================================================================
# Used by `upload-thumbnails` to push 150px character images to Supabase
# Storage. The service-role key is required because the script lists and
# uploads objects. Bucket must be created manually (public read access).
# SUPABASE_URL=https://[PROJECT-REF].supabase.co
# SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1...
# SUPABASE_THUMBNAIL_BUCKET=character-images

# =============================================================================
# USAGE EXAMPLES
# =============================================================================
# To enable parallel processing with 6 workers:
# OP_ENABLE_PARALLEL=true
# OP_MAX_WORKERS=6

# To scrape only up to chapter 1000:
# OP_LAST_CHAPTER=1000

# To use a different database location:
# OP_DATABASE_PATH=./custom/path/onepiece.duckdb

# To enable debug logging:
# OP_LOG_LEVEL=DEBUG
